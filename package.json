{
  "name": "my-lumea-assets-app",
  "version": "1.0.0",
  "description": "Web app + Cloudflare Worker (D1 + R2) for product uploads",
  "author": "example.com",
  "homepage": "https://developers.cloudflare.com/workers/",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck:worker": "tsc --noEmit -p tsconfig.worker.json --composite false",
    "typecheck": "npm run typecheck:web && npm run typecheck:worker",
    "dev:web": "vite --host 0.0.0.0 --port 5173",
    "dev:worker": "wrangler dev --config wrangler.jsonc --remote --ip 0.0.0.0 --port 8787",
    "dev": "concurrently -k \"npm:dev:worker\" \"npm:dev:web\"",
    "build": "npm run typecheck && vite build",
    "start": "vite preview --host 0.0.0.0 --port 4173",
    "deploy": "npm run build && wrangler deploy --config wrangler.jsonc"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.575.0",
    "mime-types": "^3.0.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@cloudflare/workers-types": "^4.20260304.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "wrangler": "^4.9.0"
  }
}
